{
  "name": "podman",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "load-booster-data": "tsx --env-file-if-exists=.env.local scripts/load-booster-data.ts",
    "test-packs": "tsx --env-file-if-exists=.env.local scripts/test-packs.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "backup-prod": "tsx --env-file-if-exists=.env.local scripts/backup-prod.ts",
    "sync-staging": "tsx --env-file-if-exists=.env.local scripts/sync-staging.ts",
    "restore-prod": "tsx --env-file-if-exists=.env.local scripts/restore-prod.ts",
    "update-sets": "tsx --env-file-if-exists=.env.local scripts/load-booster-data.ts --sync",
    "test:rls": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.67.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.6.1",
    "keyrune": "^3.19.0",
    "mana-font": "^1.18.0",
    "next": "16.2.11",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "ora": "^8.2.0",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
