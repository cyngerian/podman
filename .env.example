# Copy this to .env.local and fill in values
# Local dev: run `npx supabase start` and use the output values
# Staging/Production: get from Supabase dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Sentry (error monitoring)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Vercel Blob (avatar uploads)
BLOB_READ_WRITE_TOKEN=

# Upstash Redis (booster data cache — optional, KV no-ops when unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Scripts only — backup-prod / restore-prod / sync-staging / update-sets
SUPABASE_PROJECT_REF=
SUPABASE_STAGING_REF=
SUPABASE_ACCESS_TOKEN=

# Scripts only — test-packs (aliased to the runtime names at startup)
PROD_SUPABASE_URL=
PROD_SUPABASE_SECRET_KEY=
